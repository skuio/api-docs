{"parameters":[{"name":"Accept","in":"header","schema":{"type":"string"},"example":"text/csv"},{"name":"filter[type]","in":"query","schema":{"type":"string"},"description":"Filter by transaction type (comma-separated for multiple)","example":"sales_order_invoice"},{"name":"filter[status]","in":"query","schema":{"type":"string"},"description":"synced | notSynced | hasErrors","example":"synced"},{"name":"filter[sync_enabled]","in":"query","schema":{"type":"string"},"description":"yes | no","example":"yes"},{"name":"filter[has_error]","in":"query","schema":{"type":"string"},"description":"yes | no","example":"yes"},{"name":"filter[nominal_code]","in":"query","schema":{"type":"integer"},"description":"Partial match on nominal code","example":"4000"},{"name":"filter[transaction_date.from]","in":"query","schema":{"type":"string"},"description":"Transaction date from (YYYY-MM-DD)","example":"2024-01-01"},{"name":"filter[transaction_date.to]","in":"query","schema":{"type":"string"},"description":"Transaction date to (YYYY-MM-DD)","example":"2024-12-31"},{"name":"filter[search]","in":"query","schema":{"type":"string"},"description":"Search by ID, reference, name, or invoice number override","example":"INV-1001"},{"name":"sort","in":"query","schema":{"type":"string"},"description":"Sort field. Prefix - for descending. Allowed: id, transaction_date, type, reference, name, total, created_at, updated_at","example":"-transaction_date"}]}