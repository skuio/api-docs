{"parameters":[{"name":"Accept","in":"header","schema":{"type":"string"},"example":"application/json"},{"name":"page","in":"query","schema":{"type":"integer"},"description":"Page number (default: 1)","example":"1"},{"name":"limit","in":"query","schema":{"type":"integer"},"description":"Records per page (default: 15)","example":"15"},{"name":"search","in":"query","schema":{"type":"string"},"description":"General search across name and currency_code fields"},{"name":"sort","in":"query","schema":{"type":"string"},"description":"Column to sort by. Prefix with - for descending (e.g. -name)","example":"name"},{"name":"archived","in":"query","schema":{"type":"integer"},"description":"0 = active (default), 1 = archived","example":"0"},{"name":"filter[name]","in":"query","schema":{"type":"string"},"description":"Filter by name","example":"Wholesale"},{"name":"filter[currency_code]","in":"query","schema":{"type":"string"},"description":"Filter by currency code","example":"USD"},{"name":"included[]","in":"query","schema":{"type":"integer"},"description":"IDs to always include in results","example":"1"},{"name":"excluded[]","in":"query","schema":{"type":"integer"},"description":"IDs to exclude from results","example":"5"},{"name":"table_specifications","in":"query","schema":{"type":"integer"},"description":"Include table column specifications","example":"1"}]}