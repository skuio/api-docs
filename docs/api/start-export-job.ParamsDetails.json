{"parameters":[{"name":"Accept","in":"header","schema":{"type":"string"},"example":"application/json"},{"name":"format","in":"query","schema":{"type":"string"},"description":"xlsx | csv (default: xlsx)","example":"xlsx"},{"name":"content_mode","in":"query","schema":{"type":"string"},"description":"summary | detail (default: summary)","example":"summary"},{"name":"scope","in":"query","schema":{"type":"string"},"description":"filtered | selected (default: filtered)","example":"filtered"},{"name":"ids","in":"query","schema":{"type":"string"},"description":"Comma-separated IDs when scope=selected","example":"1001,1002,1003"},{"name":"columns","in":"query","schema":{"type":"string"},"description":"Comma-separated column names to include","example":"id,reference,name,total"},{"name":"filter[type]","in":"query","schema":{"type":"string"},"description":"Same filters as v3/transactions list","example":"sales_order_invoice"},{"name":"filter[transaction_date.from]","in":"query","schema":{"type":"string"},"example":"2024-01-01"},{"name":"sort","in":"query","schema":{"type":"string"},"example":"-transaction_date"}]}