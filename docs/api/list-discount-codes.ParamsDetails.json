{"parameters":[{"name":"Accept","in":"header","schema":{"type":"string"},"example":"application/json"},{"name":"search","in":"query","schema":{"type":"string"},"description":"Search by code or description","example":"SUMMER10"},{"name":"sort","in":"query","schema":{"type":"string"},"description":"Sort field. Prefix with - for descending. Allowed: code, type, scope, is_active, created_at","example":"code"},{"name":"page","in":"query","schema":{"type":"integer"},"description":"Page number","example":"1"},{"name":"limit","in":"query","schema":{"type":"integer"},"description":"Items per page","example":"10"},{"name":"archived","in":"query","schema":{"type":"integer"},"description":"0 = active, 1 = archived (soft-deleted)","example":"0"}]}