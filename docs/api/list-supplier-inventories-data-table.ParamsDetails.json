{"parameters":[{"name":"Accept","in":"header","schema":{"type":"string"},"example":"application/json"},{"name":"page","in":"query","schema":{"type":"integer"},"description":"Page number (Spatie QueryBuilder)","example":"1"},{"name":"per_page","in":"query","schema":{"type":"integer"},"description":"Records per page (default 10)","example":"15"},{"name":"sort","in":"query","schema":{"type":"string"},"description":"Sort field. Allowed: id, quantity, eta, in_stock, discontinued, created_at, updated_at. Prefix with - for descending (default: -updated_at)","example":"-updated_at"},{"name":"filter[id]","in":"query","schema":{"type":"integer"},"description":"Filter by exact ID","example":"1"},{"name":"filter[supplier_id]","in":"query","schema":{"type":"integer"},"description":"Filter by exact supplier ID","example":"1"},{"name":"filter[warehouse_id]","in":"query","schema":{"type":"integer"},"description":"Filter by exact warehouse ID","example":"2"},{"name":"filter[product_id]","in":"query","schema":{"type":"integer"},"description":"Filter by exact product ID","example":"42"},{"name":"filter[sku]","in":"query","schema":{"type":"string"},"description":"Filter by partial product SKU match","example":"WIDGET"},{"name":"filter[search]","in":"query","schema":{"type":"string"},"description":"Advanced search across product SKU","example":"WIDGET"}]}